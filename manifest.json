{
    "manifest_version": 3,
    "name": "Thoughtful Comment Ghostwriter",
    "version": "1.0.0",
    "description": "Generate high-signal comments for LinkedIn and Reddit posts using your OpenAI API key.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "downloads"
    ],
    "host_permissions": [
        "https://www.linkedin.com/*",
        "https://www.reddit.com/*",
        "https://api.openai.com/*"
    ],
    "background": {
        "service_worker": "src/background/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.linkedin.com/*",
                "https://www.reddit.com/*"
            ],
            "js": [
                "src/content/dom-utils.js",
                "src/content/linkedin.js",
                "src/content/reddit.js",
                "src/content/content.js",
                "src/content/widget.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_title": "Thoughtful Comment Ghostwriter",
        "default_popup": "src/popup/popup.html"
    },
    "options_page": "src/options/options.html"
}